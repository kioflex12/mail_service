# Скопируй в .env и заполни. .env в гит НЕ коммитим.

# Telegram
TELEGRAM_TOKEN=123456:ABC-твой-токен-от-BotFather
TELEGRAM_CHAT_ID=878394860

# OpenRouter (бесплатные модели). Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Расписание утренней проверки
DAILY_HOUR=9
TIMEZONE=Europe/Moscow

# Поиск писем
LOOKBACK_DAYS=2
MAX_THREADS=40
GMAIL_QUERY_EXTRA=in:anywhere

# Пути к Google-креденшелам (OAuth). credentials.json — из Google Cloud Console;
# token.json создастся автоматически при первом запуске (после согласия в браузере).
GOOGLE_CREDENTIALS=credentials.json
GOOGLE_TOKEN=token.json
